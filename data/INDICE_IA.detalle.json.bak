{
  "$schema_version": "1.1",
  "note": "Detalle por id. Compañero de INDICE_IA.json.",
  "repos": {
    "twenty-main": {
      "name": "twenty-main",
      "cat": 1,
      "desc": "CRM open-source orientado a desarrolladores, alternativa moderna y personalizable a Salesforce/HubSpot que modela tu negocio mediante objetos y campos propios.",
      "stack": "TypeScript, React, NestJS, PostgreSQL, Docker",
      "models_note": "opcional (plugins Claude Code/Codex para consultar el CRM en lenguaje natural).",
      "choose_if": "quieres un CRM que se adapte 1:1 a tu negocio",
      "avoid_if": "buscas algo plug-and-play sin self-host.",
      "combines_with": [
        "evolution-api",
        "n8n"
      ],
      "alternatives": [],
      "repo": "https://github.com/twentyhq/twenty",
      "doc": "human/fichas/twenty-main.md"
    },
    "evolution-api": {
      "name": "evolution-api",
      "cat": 1,
      "desc": "API REST robusta que actúa como middleware para automatizar WhatsApp y mensajería multicanal, exponiendo el envío/recepción de mensajes a tus aplicaciones.",
      "stack": "Node.js/TypeScript, Fastify, Redis, Docker",
      "models_note": "no usa IA directa; es el puente al LLM.",
      "choose_if": "operas WhatsApp en producción",
      "avoid_if": "solo necesitas un bot de prueba.",
      "combines_with": [
        "n8n",
        "chatwoot"
      ],
      "alternatives": [],
      "repo": "https://github.com/EvolutionAPI/evolution-api",
      "doc": "human/fichas/evolution-api.md"
    },
    "openwa": {
      "name": "OpenWA",
      "cat": 1,
      "desc": "gateway/SDK abierto para conectar y automatizar cuentas de WhatsApp de forma directa desde código, sin infraestructura pesada.",
      "stack": "Python, JavaScript/Node.js",
      "models_note": "no nativa (requiere orquestación externa).",
      "choose_if": "desarrollas scripts independientes",
      "avoid_if": "necesitas infra multi-instancia.",
      "combines_with": [
        "n8n",
        "evolution-api"
      ],
      "alternatives": [],
      "repo": "https://github.com/open-wa/wa-automate-nodejs",
      "doc": "human/fichas/openwa.md"
    },
