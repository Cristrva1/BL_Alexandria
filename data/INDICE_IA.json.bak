{
  "$schema_version": "1.1",
  "meta": {
    "title": "Índice IA — 156 repos curados (171 detectados) de IA & Automatización",
    "purpose": "Que un agente seleccione repos útiles con bajo gasto de tokens. Empieza por AGENTS.md.",
    "how_to_use": [
      "1. Lee solo este JSON. Filtra por cat/tags/role/exec/prov/one.",
      "2. Desempata con 'alt' (descarta alternativas del repo ya elegido).",
      "3. Para flujos completos usa 'recipes'.",
      "4. Considera la herramienta del usuario con 'model_guidance' y 'agent_tools'.",
      "5. Solo para finalistas: abre INDICE_IA.detalle.json por id, o el 'doc'."
    ],
    "tiers": {
      "scan": "INDICE_IA.json (este)",
      "detail": "INDICE_IA.detalle.json",
      "human": "human/categorias/NN-*.md (y human/fichas/*.md)"
    },
    "fields": {
      "exec": "local/cloud/hybrid",
      "role": "platform/runtime/library/skill/directory/app",
      "setup": "easy/medium/heavy",
      "mcp": "expone/consume MCP",
      "prov": "openai/anthropic/google/mcp/local; []=no declarado",
      "alt": "sustitutos (elige uno)",
      "agent_tools": "presente solo si es específico de una herramienta"
    }
  },
  "legend": {
    "exec": {
      "local": "🏠",
      "cloud": "☁️",
      "hybrid": "🔀"
    },
    "role": {
      "platform": "⚙️",
      "runtime": "🧩",
      "library": "📚",
      "skill": "🎨",
      "directory": "📂",
      "app": "🖥️"
    },
    "setup": {
      "easy": "🟢",
      "medium": "🟡",
      "heavy": "🔴"
    }
  },
  "model_guidance": {
    "key_distinction": "Separa el AGENTE/IDE con el que CONSTRUYES (Antigravity, Codex, Claude Code, Grok, Deepseek) del LLM que tu APP llama EN EJECUCIÓN (campo 'prov'). La mayoría de repos runtime son AGNÓSTICOS al agente de código.",
    "rule_of_thumb": "Filtra por 'agent_tools' solo en repos de tipo skill/directory; el resto se elige por función.",
    "tools": {
      "claude-code": {
        "best_fit_repos": [
          "claude-plugins-official",
          "awesome-claude-code",
          "superpowers",
          "skills",
          "agent-toolkit",
          "n8n-skills",
          "geo-seo-claude",
          "agency-agents"
        ]
      },
      "antigravity": {
        "best_fit_repos": [
          "antigravity-awesome-skills",
          "awesome-agent-skills",
          "prompt-master"
        ]
      },
      "codex": {
        "best_fit_repos": [
          "antigravity-awesome-skills",
          "awesome-agent-skills",
          "marketingskills",
          "taste-skill"
        ]
      },
      "grok": {
        "best_fit_repos": [],
        "note": "Sin repos específicos; úsalo como proveedor LLM en runtime."
      },
      "deepseek": {
        "best_fit_repos": [
          "deepseek-coder"
        ],
        "note": "Es el modelo; el resto es agnóstico vía proveedor compatible OpenAI."
      }
    }
  },
