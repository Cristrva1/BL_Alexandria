  "recipes": [
    {
      "id": "bot-de-whatsapp-con-ia",
      "title": "Bot de WhatsApp con IA",
      "goal": "atención/ventas automatizada por WhatsApp con un agente LLM.",
      "repos": [
        "evolution-api",
        "n8n",
        "n8n-mcp",
        "n8n-skills",
        "chatwoot",
        "novu"
      ],
      "how": "evolution-api recibe/envía mensajes vía webhook; n8n enruta y llama al LLM; chatwoot centraliza cuando entra un agente humano."
    },
    {
      "id": "pipeline-de-reels-video-corto",
